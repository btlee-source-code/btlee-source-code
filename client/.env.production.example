###############################################################################
#  Bt Lee — FRONTEND production environment variables
#  Paste these into Vercel → Project → Settings → Environment Variables.
#  NEXT_PUBLIC_* values are embedded at build time, so changing them needs a
#  redeploy. Replace every <...> placeholder.
###############################################################################

# ── API origin (same-origin proxy) ───────────────────────────────────────────
# The browser must call OUR OWN origin so the auth cookie stays first-party and
# works on mobile / iOS Safari. So this is the relative path "/api" — NOT the
# Railway URL. Vercel rewrites /api/* to the backend (see API_PROXY_TARGET).
NEXT_PUBLIC_API_URL=/api

# Where Vercel proxies /api/* to — your Railway backend ORIGIN, with NO /api and
# NO trailing slash. This is a server-side var (not NEXT_PUBLIC); it's read by
# next.config.ts at build/runtime. Changing it requires a redeploy.
API_PROXY_TARGET=https://btlee-api.up.railway.app

# ── Maps ──────────────────────────────────────────────────────────────────────
# Property location map + add-property picker use OpenStreetMap via Leaflet.
# Free OSM tile server — no API key or billing required.

# ── Site metadata ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://btlee.vercel.app
NEXT_PUBLIC_SITE_NAME=بيت لي