# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Firebase — contains a real API key, never commit. Supplied per-environment
# (EAS Secrets or local placement) at build time.
google-services.json
GoogleService-Info.plist

# Firebase Admin SDK service account key — full admin credential, never commit.
# Used once to upload FCM V1 push credentials to EAS, then can be deleted.
firebase-adminsdk.json

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

example

# generated native folders
/ios
/android
