###############################################################################
#  Bt Lee — BACKEND production environment variables
#  Copy this whole file into your host (Railway → Variables → Raw Editor,
#  or Render → Environment). Replace every <...> with a real value.
#  Everything WITHOUT <...> is already correct — leave it exactly as-is.
#  NEVER commit the filled-in version.
###############################################################################

NODE_ENV=production
# PORT is injected by the host automatically — leave it unset.

# ── Frontend origin (CORS + cookies + email links) — no trailing slash ──
CLIENT_URL=https://btlee.vercel.app
# OPTIONAL — extra browser origins, comma-separated. Leave commented if unsure.
# CORS_EXTRA_ORIGINS=https://www.btlee.com,https://btlee-git-main.vercel.app

# ── Database — MongoDB Atlas ──
# In Atlas → Network Access, add 0.0.0.0/0 so the host's dynamic IP can connect.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/btlee_db?retryWrites=true&w=majority

# ── Location search (optional; defaults to the public Nominatim endpoint) ──
GEOCODING_SEARCH_URL=https://nominatim.openstreetmap.org/search

# ── JWT secrets ──
# Generate TWO DIFFERENT values, each by running this once:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=<generated-hex-1>
JWT_REFRESH_SECRET=<generated-hex-2-must-differ-from-1>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Auth cookies ──
# The frontend proxies /api/* to this backend (see client API_PROXY_TARGET), so
# the browser sees the API as SAME-ORIGIN and the cookie is first-party. Keep
# 'lax' and leave COOKIE_DOMAIN UNSET so the cookie is scoped to the Vercel host
# the browser actually called. This is what makes login persist on mobile/iOS.
# (Do NOT set 'none' here — that's only for a direct cross-site API, which iOS
#  Safari may still block.)
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN — leave empty/unset for the proxy setup above. Only set it if
# the frontend + API genuinely share a parent domain (e.g. .btlee.com).
# COOKIE_DOMAIN=

# ── Cloudinary (property image uploads) ──
CLOUDINARY_CLOUD_NAME=<cloud-name>
CLOUDINARY_API_KEY=<api-key>
CLOUDINARY_API_SECRET=<api-secret>

# ── Email (Gmail SMTP) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your-gmail-address>
# Gmail App Password (needs 2FA enabled) — NOT your normal login password.
SMTP_PASS=<gmail-app-password>
# Keep EMAIL_FROM on your Gmail address — Gmail rejects a different sender.
EMAIL_FROM=بيت لي <your-gmail-address>

# ── Seed admin (created once via `npm run seed`) — min 10 chars, letters + numbers ──
ADMIN_EMAIL=admin@btlee.com
ADMIN_PASSWORD=<strong-unique-password>
