# Server Configuration
NODE_ENV=development
PORT=5000
# The exact origin of the frontend. Used for CORS + CSRF origin checks + cookies.
# In production this MUST be the real https origin (e.g. https://btlee.com).
CLIENT_URL=http://localhost:3000

# Auth cookies
# 'lax' is correct when the browser sees the API as same-site — including the
# Vercel same-origin proxy setup (frontend proxies /api/* to this backend, see
# the client's API_PROXY_TARGET). Keep COOKIE_DOMAIN empty in that case so the
# cookie is scoped to the host the browser actually called.
# Only use 'none' for a DIRECT cross-site API (different domains) — note iOS
# Safari may still block it, which is exactly why the proxy setup is preferred.
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=

# MongoDB
MONGODB_URI=mongodb://localhost:27017/btlee

# Optional Nominatim-compatible search provider. The built-in default is shown.
GEOCODING_SEARCH_URL=https://nominatim.openstreetmap.org/search

# JWT Authentication
# IMPORTANT: secrets must be at least 32 chars and cryptographically random.
# Generate strong values with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# NEVER reuse these example values in production.
JWT_ACCESS_SECRET=replace-with-64-hex-chars-from-the-command-above
JWT_REFRESH_SECRET=replace-with-a-DIFFERENT-64-hex-chars-value
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth (social login) — optional. Leave unset to disable the Google
# button. Create credentials at https://console.cloud.google.com → APIs &
# Services → Credentials → OAuth client ID (Web application).
# The callback URL must EXACTLY match an "Authorized redirect URI" there.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Cloudinary (Image Hosting)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email (Nodemailer SMTP)
# SMTP — works locally and on hosts that allow outbound SMTP.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=your-email@your-domain.com
SMTP_PASS=your-email-password
EMAIL_FROM=Bt Lee <noreply@your-domain.com>

# Resend HTTP API (optional) — REQUIRED on hosts that block SMTP ports such as
# Railway. When set, emails are sent via Resend over HTTPS instead of SMTP.
# Get a key + verify your domain at https://resend.com
RESEND_API_KEY=

# Admin Default (used by seed only — use a strong, unique password)
ADMIN_EMAIL=admin@btlee.com
ADMIN_PASSWORD=change-this-to-a-strong-password
