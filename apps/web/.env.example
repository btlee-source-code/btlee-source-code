# API
# DEV: point straight at the local backend (full URL).
# PROD (Vercel): set this to EXACTLY "/api" — just the path, with NO domain/link.
#   This makes the browser call our OWN origin so the auth cookie stays
#   first-party (works on mobile / iOS Safari). Vercel then proxies /api/* to
#   the backend (see API_PROXY_TARGET below).
#     ✅ correct (prod):  NEXT_PUBLIC_API_URL=/api
#     ❌ wrong   (prod):  NEXT_PUBLIC_API_URL=https://your-app.up.railway.app/api
#   (Ending in /api is NOT enough — any domain in front makes it cross-site and
#    breaks login on mobile. Only API_PROXY_TARGET carries the Railway link.)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Same-origin API proxy target (PROD only — leave empty in dev).
# When set, next.config.ts rewrites /api/* on the frontend to this backend
# origin, so the browser never talks to the API cross-site. Set it on Vercel to
# your Railway backend ORIGIN, with NO trailing /api and NO trailing slash:
#   API_PROXY_TARGET=https://your-app.up.railway.app
# If this is NOT set, the proxy is OFF and /api/* won't be rewritten.
API_PROXY_TARGET=

# Maps: OpenStreetMap via Leaflet — no API key required.

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=بيت لي